[Unit]
Description=Servidor Minecraft Java
After=network.target

[Service]
User=vinicius
WorkingDirectory=/home/vinicius/minecraft
ExecStart=/usr/bin/screen -DmS minecraft /usr/bin/java -Xmx4G -Xms2G -jar server.jar nogui
ExecStop=/usr/bin/screen -p 0 -S minecraft -X eval 'stuff "stop"\015'
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
